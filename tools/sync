#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.9"
# dependencies = ["pyyaml"]
# ///
"""tools/sync — reconstruct the read-only ``mirror/`` from pinned upstream SHAs.

This repository is DOWNSTREAM of six live QuantEcon lecture series. It mirrors
an allowlisted subset of each series (``lectures/`` and ``environment.yml``) into
``mirror/<key>/``. That mirror is a pure function of ``(repo, pinned SHA,
allowlist)``, so it is never committed — only the pinned SHAs in
``sync/state.yml`` are committed, and the mirror is rebuilt on demand from them.

Two files drive this script:

* ``sync/manifest.yml`` — HUMAN INTENT: which repos feed the mirror, on which
  branch, and which paths are allowlisted.
* ``sync/state.yml``    — MACHINE STATE: the exact SHA each series is pinned to
  (written by this script; do not hand-edit).

Usage
-----
    tools/sync                     # reconstruct all series at their pinned SHAs
    tools/sync dp jax              # reconstruct only the named series
    tools/sync --update            # re-pin every series to HEAD, then rebuild
    tools/sync --update dp         # re-pin + rebuild only dp
    tools/sync --update --pin-only # re-pin every series, but do NOT download
    tools/sync --pin-only          # (implies resolve) write SHAs, skip rebuild

Flags
-----
    --update     re-resolve each selected series' HEAD via ``git ls-remote`` and
                 re-pin the SHA (with a UTC ``synced_at`` timestamp) into
                 sync/state.yml — but only when the resolved HEAD actually
                 differs from the already-pinned SHA.
    --pin-only   resolve and write SHAs but SKIP reconstruction (no downloads).
    -h/--help    show help and exit.

This script NEVER commits anything — CI is responsible for committing the
refreshed sync/state.yml.
"""

from __future__ import annotations

import argparse
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

try:
    import yaml
except ImportError:  # pragma: no cover - dependency is declared in PEP-723 block
    sys.stderr.write(
        "error: PyYAML is required. Run this script via `uv run` (the shebang\n"
        "       `#!/usr/bin/env -S uv run --script` handles the dependency), or\n"
        "       install it with `pip install pyyaml`.\n"
    )
    sys.exit(1)


# --------------------------------------------------------------------------- #
# Paths (resolved relative to the repo root, derived from this script's own    #
# location, so the script works from any current working directory).           #
# --------------------------------------------------------------------------- #
SCRIPT_PATH = Path(__file__).resolve()
REPO_ROOT = SCRIPT_PATH.parent.parent
SYNC_DIR = REPO_ROOT / "sync"
MANIFEST_PATH = SYNC_DIR / "manifest.yml"
STATE_PATH = SYNC_DIR / "state.yml"
MIRROR_DIR = REPO_ROOT / "mirror"

# Sensible fallbacks if the manifest omits a `defaults` block.
DEFAULT_BRANCH = "main"
DEFAULT_PATHS = ["lectures/", "environment.yml"]

# Byte-identical to the committed sync/state.yml header, so round-tripping the
# state file (regenerate then diff) is a no-op when nothing upstream moved.
STATE_HEADER = (
    "# generated by tools/sync — do not hand-edit\n"
    "# Machine state: the exact commit each series is pinned to.\n"
    "# Refresh with `tools/sync --update` (or `--update --pin-only` in CI).\n"
)


class SyncError(Exception):
    """A recoverable, per-series error. Reported, then the run continues."""


# --------------------------------------------------------------------------- #
# Small helpers                                                                #
# --------------------------------------------------------------------------- #
def now_iso() -> str:
    """Current time as an RFC-3339 UTC timestamp, e.g. 2026-07-08T04:15:09Z."""
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def repo_url(owner_name: str) -> str:
    """Build the HTTPS clone URL for an ``owner/name`` GitHub repo reference."""
    return f"https://github.com/{owner_name}.git"


def git(args, cwd=None) -> str:
    """Run a git command, returning combined stdout+stderr on success.

    Raises SyncError with the captured output on failure so callers can report
    a clear per-series message and carry on.
    """
    try:
        proc = subprocess.run(
            ["git", *args],
            cwd=str(cwd) if cwd is not None else None,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
        )
    except OSError as exc:  # git vanished mid-run, permissions, etc.
        raise SyncError(f"failed to run `git {' '.join(args)}`: {exc}") from exc
    if proc.returncode != 0:
        detail = proc.stdout.strip()
        raise SyncError(
            f"`git {' '.join(args)}` exited {proc.returncode}"
            + (f":\n    {detail}" if detail else "")
        )
    return proc.stdout


# --------------------------------------------------------------------------- #
# Manifest + state I/O                                                         #
# --------------------------------------------------------------------------- #
def load_yaml(path: Path):
    """Load a YAML mapping, tolerating an empty/None document (-> {})."""
    if not path.exists():
        return None
    try:
        data = yaml.safe_load(path.read_text()) or {}
    except yaml.YAMLError as exc:
        raise SystemExit(f"error: could not parse {path}:\n{exc}")
    if not isinstance(data, dict):
        raise SystemExit(f"error: expected a mapping at the top of {path}.")
    return data


def load_manifest():
    """Return an ordered mapping ``key -> {repo, branch, paths}``.

    ``defaults`` (branch/paths) apply to every series unless a series stanza
    overrides them.
    """
    data = load_yaml(MANIFEST_PATH)
    if data is None:
        raise SystemExit(
            f"error: manifest not found at {MANIFEST_PATH}.\n"
            "       This file is the source of truth for which repos feed the "
            "mirror.\n"
            "       Restore sync/manifest.yml before running tools/sync."
        )

    defaults = data.get("defaults") or {}
    default_branch = defaults.get("branch", DEFAULT_BRANCH)
    default_paths = defaults.get("paths", DEFAULT_PATHS)

    series_block = data.get("series") or {}
    if not isinstance(series_block, dict) or not series_block:
        raise SystemExit(
            f"error: {MANIFEST_PATH} has no `series:` mapping — nothing to sync."
        )

    manifest = {}
    for key, cfg in series_block.items():
        cfg = cfg or {}
        repo = cfg.get("repo")
        if not repo:
            raise SystemExit(
                f"error: series '{key}' in {MANIFEST_PATH} is missing `repo:`."
            )
        manifest[key] = {
            "repo": repo,
            "branch": cfg.get("branch", default_branch),
            "paths": cfg.get("paths", default_paths),
        }
    return manifest


def load_state():
    """Return the pinned-SHA state mapping (``{}`` if the file is absent)."""
    data = load_yaml(STATE_PATH)
    return data if data else {}


def write_state(state, order):
    """Write sync/state.yml in manifest order, with the do-not-edit header.

    Every series key from the manifest is represented, so the file stays a
    complete template even when only a subset was refreshed.
    """
    ordered = {}
    for key in order:
        entry = state.get(key) or {}
        ordered[key] = {
            "sha": entry.get("sha", "") or "",
            "synced_at": entry.get("synced_at", "") or "",
        }
    SYNC_DIR.mkdir(parents=True, exist_ok=True)
    body = yaml.safe_dump(ordered, sort_keys=False, default_flow_style=False)
    STATE_PATH.write_text(STATE_HEADER + body)


# --------------------------------------------------------------------------- #
# Core operations                                                              #
# --------------------------------------------------------------------------- #
def resolve_head(url: str, branch: str) -> str:
    """Resolve the current HEAD SHA of ``refs/heads/<branch>`` on ``url``."""
    out = git(["ls-remote", url, f"refs/heads/{branch}"])
    lines = [ln for ln in out.splitlines() if ln.strip()]
    if not lines:
        raise SyncError(
            f"no ref `refs/heads/{branch}` advertised by {url} "
            "(wrong branch name, private repo, or network failure?)"
        )
    sha = lines[0].split()[0]
    if not sha:
        raise SyncError(f"could not parse a SHA from `git ls-remote` on {url}")
    return sha


def sparse_patterns(paths):
    """Translate the allowlist into anchored ``--no-cone`` sparse patterns.

    Non-cone sparse-checkout takes gitignore-style patterns. Anchoring each
    allowlist entry with a leading ``/`` restricts the checkout to exactly the
    named top-level directories and files — so ``mirror/<key>/`` is a true
    byte-for-byte function of (repo, SHA, allowlist), with no stray root files.
    Cone mode is deliberately NOT used: it always materialises every top-level
    file, which would over-include beyond the declared allowlist.
    """
    patterns = []
    seen = set()
    for raw in paths:
        p = str(raw).strip()
        if not p:
            continue
        pattern = p if p.startswith("/") else "/" + p
        if pattern not in seen:
            seen.add(pattern)
            patterns.append(pattern)
    return patterns


def reconstruct(key: str, url: str, sha: str, paths):
    """Rebuild ``mirror/<key>/`` as plain files pinned to ``sha``.

    Fresh directory, git init, remote, non-cone sparse-checkout anchored to the
    allowlist, a shallow fetch of the exact SHA, checkout, then the nested
    ``.git`` is removed so the mirror is inert plain files. The ``.git`` removal
    runs in a ``finally`` so a mid-run failure never leaves a live nested repo.
    """
    dest = MIRROR_DIR / key
    if dest.exists():
        shutil.rmtree(dest)
    dest.mkdir(parents=True)

    try:
        git(["init", "-q"], cwd=dest)
        git(["remote", "add", "origin", url], cwd=dest)

        git(["sparse-checkout", "set", "--no-cone", *sparse_patterns(paths)], cwd=dest)

        try:
            git(["fetch", "--depth", "1", "origin", sha], cwd=dest)
        except SyncError as exc:
            raise SyncError(
                f"{exc}\n    the pinned SHA {sha[:12]} may be stale or "
                f"unreachable; try `tools/sync --update {key}` to re-pin to "
                "the current HEAD."
            )
        git(["checkout", "-q", "FETCH_HEAD"], cwd=dest)
    finally:
        # Drop the nested repository so mirror/<key>/ is a plain, inert tree —
        # even if fetch/checkout failed part-way through.
        git_dir = dest / ".git"
        if git_dir.exists():
            shutil.rmtree(git_dir, ignore_errors=True)


# --------------------------------------------------------------------------- #
# CLI                                                                          #
# --------------------------------------------------------------------------- #
def build_parser():
    parser = argparse.ArgumentParser(
        prog="tools/sync",
        description=(
            "Reconstruct the read-only mirror/ from pinned upstream SHAs. "
            "With --update, re-pin each series to its current HEAD first."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Series keys are defined in sync/manifest.yml.",
    )
    parser.add_argument(
        "keys",
        nargs="*",
        metavar="SERIES",
        help="series keys to operate on (default: all series in the manifest).",
    )
    parser.add_argument(
        "--update",
        action="store_true",
        help="re-resolve each selected series' HEAD and re-pin its SHA "
        "(only when the HEAD actually moved).",
    )
    parser.add_argument(
        "--pin-only",
        action="store_true",
        help="resolve and write SHAs but skip reconstruction (no downloads).",
    )
    return parser


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)

    # Parse args (and handle -h/--help) BEFORE the git check or manifest load,
    # so `tools/sync --help` works on a fresh checkout and without git present.
    parser = build_parser()
    args = parser.parse_args(argv)

    if shutil.which("git") is None:
        sys.stderr.write(
            "error: `git` was not found on PATH. tools/sync drives git to "
            "reconstruct the mirror; please install git and try again.\n"
        )
        return 2

    manifest = load_manifest()
    valid_keys = list(manifest.keys())

    if args.keys:
        unknown = [k for k in args.keys if k not in valid_keys]
        if unknown:
            parser.error(
                "unknown series key(s): "
                + ", ".join(unknown)
                + "\nvalid keys: "
                + ", ".join(valid_keys)
            )
        # Preserve manifest order, drop duplicates.
        selected = [k for k in valid_keys if k in set(args.keys)]
    else:
        selected = list(valid_keys)

    # --pin-only implies resolving the SHA (it just skips the download).
    do_resolve = args.update or args.pin_only
    do_reconstruct = not args.pin_only

    state = load_state()

    if not do_resolve:
        # Reconstruction-only mode needs SHAs already on disk.
        if not STATE_PATH.exists():
            sys.stderr.write(
                f"error: no pinned SHAs found — {STATE_PATH} does not exist.\n"
                "       Run `tools/sync --update` to resolve and pin HEADs "
                "first.\n"
            )
            return 2

    MIRROR_DIR.mkdir(parents=True, exist_ok=True)

    results = []  # list of (key, ok: bool)
    for key in selected:
        cfg = manifest[key]
        url = repo_url(cfg["repo"])
        try:
            if do_resolve:
                new_sha = resolve_head(url, cfg["branch"])
                old_sha = ((state.get(key) or {}).get("sha") or "").strip()
                if new_sha != old_sha:
                    state[key] = {"sha": new_sha, "synced_at": now_iso()}
                    # Persist immediately so a later failure keeps this pin.
                    # Only write on real movement, so CI commits track genuine
                    # upstream changes rather than timestamp churn.
                    write_state(state, valid_keys)
                    print(
                        f"[{key}] pinned {cfg['repo']}@{new_sha[:12]} "
                        f"({cfg['branch']})"
                    )
                else:
                    print(f"[{key}] unchanged @ {new_sha[:12]} ({cfg['branch']})")
                sha = new_sha
            else:
                sha = ((state.get(key) or {}).get("sha") or "").strip()
                if not sha:
                    raise SyncError(
                        f"no pinned SHA for '{key}' in {STATE_PATH.name} — run "
                        f"`tools/sync --update {key}` to pin it first."
                    )

            if do_reconstruct:
                print(f"[{key}] reconstructing mirror/{key}/ @ {sha[:12]} …")
                reconstruct(key, url, sha, cfg["paths"])
                print(f"[{key}] done -> {MIRROR_DIR / key}")

            results.append((key, True))
        except SyncError as exc:
            sys.stderr.write(f"[{key}] FAILED: {exc}\n")
            results.append((key, False))
        except Exception as exc:  # never let one series abort the rest
            sys.stderr.write(f"[{key}] FAILED (unexpected): {exc}\n")
            results.append((key, False))

    # ----------------------------------------------------------------------- #
    # Summary                                                                  #
    # ----------------------------------------------------------------------- #
    failed = [key for key, ok in results if not ok]
    passed = [key for key, ok in results if ok]

    print("\n" + "─" * 60)
    mode = (
        "pin-only (resolve, no download)"
        if args.pin_only
        else ("update + reconstruct" if args.update else "reconstruct")
    )
    print(f"summary [{mode}]: {len(passed)} ok, {len(failed)} failed")
    if passed:
        print("  PASS: " + ", ".join(passed))
    if failed:
        print("  FAIL: " + ", ".join(failed))
    print("─" * 60)

    return 1 if failed else 0


if __name__ == "__main__":
    sys.exit(main())
